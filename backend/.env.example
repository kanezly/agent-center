# 复制此文件为 .env 并根据需要修改

# 服务器配置
PORT=8010             # API 服务端口

# 调度器配置
# 最大并发任务数（1-32）
MAX_CONCURRENT=10

# 数据库配置
DB_PATH=/app/data/task_manager.db

# CORS 配置 (逗号分隔的允许源)
# 后端启动时自动获取本机所有 IP，为每个 IP 的 3010 端口生成允许的 origin
CORS_ORIGINS_STR=http://localhost:3010,http://127.0.0.1:3010,http://0.0.0.0:3010

# 任务超时配置（秒）
# 任务执行的最大时长，超过此时间将被强制终止
# 范围：60-86400 秒（1 分钟 -24 小时）
TASK_TIMEOUT=3600

# 后处理超时配置（秒）
# 后处理（merge/cleanup）的最大执行时间
# 范围：60-3600 秒（1 分钟 -1 小时）
POST_PROCESS_TIMEOUT=600

# 认证配置 ⚠️ 必须设置！
# 未设置密码时，任何知道您 IP 的人都可以访问系统、执行任意命令！
# 建议使用强密码（大小写 + 数字 + 符号，至少 12 位）
PASSWORD=请设置强密码并妥善保管

# Session 有效期（秒）
# 范围：3600-604800 秒（1 小时 -7 天）
SESSION_MAX_AGE=604800

# Agent 后端配置
# 指定默认使用的 Agent 后端名称
# 当前支持：claude
# 未来支持：pi-agent、openmanus等
AGENT_BACKEND=claude
